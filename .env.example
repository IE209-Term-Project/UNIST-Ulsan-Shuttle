# 이 파일을 복사해 .env 로 저장하고 값을 채우세요 (.env는 git에 안 올라감)
#   cp .env.example .env
# 절대 실제 키를 .env.example 에 적지 말 것. .env 에만.

OPENAI_API_KEY=sk-여기에_OpenAI_키
ULSAN_BIS_API_KEY=여기에_울산BIS_키

# 서비스 계정 키: 둘 중 하나만 쓰면 됨
# (로컬 권장) 다운로드한 JSON 파일 경로
GOOGLE_SERVICE_ACCOUNT_FILE=./service_account.json
# (또는) JSON 내용을 한 줄로 — HF Spaces Secret 에서는 이 방식 사용
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account", ...}

# A-1에서 복사한 시트 ID
RESERVATION_SHEET_ID=여기에_시트ID
